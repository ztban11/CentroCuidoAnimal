
@model CentroCuidoAnimal.ViewModels.RegistroAnimal_ViewModel

@{
    ViewBag.Title = "Paso1";
}

<h2>Paso 1 de 3 - Información Básica</h2>

    <div class="wizard-container">
        <div class="step-title">Paso 1 de 3</div>
        <div class="wizard-bar">
            <div class="wizard-progress" style="width:33%;"></div>
        </div>
    </div>

<br />


@using (Html.BeginForm("Paso1", "Animal", FormMethod.Post))
{
    <div>
        <label>Nombre:</label>
        @Html.TextBoxFor(m => m.sNombre)
    </div>

    <br />

    <div>
        <label>Especie:</label>
        @Html.TextBoxFor(m => m.sEspecie)
    </div>

    <br />

    <div>
        <label>Edad:</label>
        @Html.TextBoxFor(m => m.iEdad)
    </div>

    <br />

    <div>
        <label>Género:</label>
        @Html.TextBoxFor(m => m.sGenero)
    </div>

    <br />

    <button type="submit">Siguiente</button>
}

